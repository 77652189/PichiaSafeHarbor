{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pichia-safe-harbor/acceptance-manifest/v1",
  "title": "PichiaSafeHarbor Slice Acceptance Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "acceptance_version",
    "run_id",
    "execution_status",
    "verification_status",
    "scientific_acceptance_status",
    "scientific_acceptance_blockers",
    "inputs",
    "run_manifest",
    "artifacts",
    "verification_evidence",
    "completeness_summary"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "acceptance_version": {"type": "string"},
    "run_id": {"type": "string", "pattern": "^slice0-[0-9a-f]{16}$"},
    "execution_status": {"enum": ["pending", "running", "complete", "failed"]},
    "verification_status": {"enum": ["not_run", "passed", "failed"]},
    "scientific_acceptance_status": {"enum": ["pending", "accepted", "blocked", "rejected"]},
    "scientific_acceptance_blockers": {"type": "array", "items": {"type": "string"}},
    "inputs": {"type": "object"},
    "run_manifest": {"$ref": "#/$defs/fileIdentity"},
    "artifacts": {"type": "object", "additionalProperties": {"$ref": "#/$defs/fileIdentity"}},
    "verification_evidence": {"type": "object"},
    "completeness_summary": {"type": "object"}
  },
  "$defs": {
    "fileIdentity": {
      "type": "object",
      "required": ["size_bytes", "sha256"],
      "properties": {
        "size_bytes": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}

