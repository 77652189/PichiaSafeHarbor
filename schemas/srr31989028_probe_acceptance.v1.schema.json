      "additionalProperties": false,
      "properties": {
        "alignment.bam": {"$ref": "#/$defs/identity"}, "alignment.bam.bai": {"$ref": "#/$defs/identity"}, "hisat2_summary.txt": {"$ref": "#/$defs/identity"}, "hisat2_stderr.txt": {"$ref": "#/$defs/identity"}, "flagstat.json": {"$ref": "#/$defs/identity"}, "samtools_stats.txt": {"$ref": "#/$defs/identity"}, "pair_mapping_summary.json": {"$ref": "#/$defs/identity"}, "splice_junctions.tsv": {"$ref": "#/$defs/identity"}, "coverage_summary.json": {"$ref": "#/$defs/identity"}, "coverage_windows.tsv": {"$ref": "#/$defs/identity"}, "coverage_anomalies.tsv": {"$ref": "#/$defs/identity"}, "univec_all_pairs_summary.txt": {"$ref": "#/$defs/identity"}, "univec_both_unmapped_summary.txt": {"$ref": "#/$defs/identity"}, "engineering_impact.json": {"$ref": "#/$defs/identity"}, "capability_report.json": {"$ref": "#/$defs/identity"}, "capability_report.md": {"$ref": "#/$defs/identity"}
