    "protectedEvidence": {"type": "object", "required": ["acceptance_sha256", "run_manifest_sha256", "artifact_sha256"], "additionalProperties": false, "properties": {"acceptance_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "run_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "artifact_sha256": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}}}
